#!/bin/sh
# Pre-commit hook: block secrets from public repo

if git diff --cached --name-only | grep -q '^config/database\.php$'; then
  echo "ERROR: config/database.php must not be committed (contains DB password)."
  exit 1
fi

if git diff --cached --name-only | grep -qE '^\.env$|^\.env\.'; then
  echo "ERROR: .env files must not be committed."
  exit 1
fi

# Block obvious secret patterns in staged content
if git diff --cached -U0 | grep -qE "gho_[A-Za-z0-9]+|ghp_[A-Za-z0-9]+"; then
  echo "ERROR: GitHub token detected in staged changes."
  exit 1
fi

if git diff --cached -U0 config/ 2>/dev/null | grep -qE "password['\"]?\s*=>\s*['\"][^'\"]*(ShS<|FpAiyh)"; then
  echo "ERROR: Real database password detected in config."
  exit 1
fi

exit 0
